  "version": "1.0.0",
  "description": "NestJS API example with GET, POST, PUT, DELETE",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
